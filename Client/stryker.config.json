{
  "$schema": "https://stryker-mutator.io/schemas/stryker-schema.json#",
  "testRunner": "vitest",
  "vitest": {
    "configFile": "vite.config.ts"
  },
  "checkers": ["typescript"],
  "typescript": {
    "tsconfigFile": "tsconfig.app.json"
  },
  "mutate": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "!src/**/*.test.ts",
    "!src/**/*.test.tsx",
    "!src/main.tsx",
    "!src/test/**",
    "!src/mocks/**"
  ],
  "reporters": ["html", "clear-text", "progress"],
  "coverageAnalysis": "perTest"
}
